# Copy this file to .env and fill in the values for your environment.
# Never commit .env — it is listed in .gitignore.

# Base URL of the common-service (auth, users, notifications, payments)
VITE_COMMON_BASE_URL=http://localhost:5001

# Base URL of the appointment-service
VITE_APPOINTMENT_BASE_URL=http://localhost:5002

# Base URL of the doctor-service
VITE_DOCTOR_BASE_URL=http://localhost:5003

# Base URL of the patient-service
VITE_PATIENT_BASE_URL=http://localhost:5004
